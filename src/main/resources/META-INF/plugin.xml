<idea-plugin>
    <id>io.nextflow.jetbrains</id>
    <name>Nextflow</name>
    <vendor url="https://github.com/forest-d">Forest Dussault</vendor>

    <description><![CDATA[
        <p>Nextflow language support for JetBrains IDEs.</p>
        <ul>
            <li>Syntax highlighting for .nf, .nf.test, and nextflow.config files</li>
            <li>Code completion, diagnostics, hover, go-to-definition, references, rename, and formatting</li>
            <li>Workflow DAG preview</li>
            <li>Project structure view for processes, workflows, and functions</li>
        </ul>
        <p>Powered by the <a href="https://github.com/nextflow-io/language-server">Nextflow Language Server</a>.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.textmate</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity
                implementation="io.nextflow.intellij.NextflowStartupActivity"/>

        <applicationConfigurable
                parentId="language"
                instance="io.nextflow.intellij.settings.NextflowSettingsConfigurable"
                id="preferences.nextflow"
                displayName="Nextflow"/>

        <toolWindow
                id="Nextflow"
                anchor="left"
                icon="/icons/nextflow.svg"
                factoryClass="io.nextflow.intellij.project.NextflowProjectToolWindowFactory"/>

        <fileEditorProvider
                implementation="io.nextflow.intellij.dag.NextflowDagPreviewEditorProvider"/>

        <notificationGroup
                id="Nextflow"
                displayType="BALLOON"/>

        <statusBarWidgetFactory
                id="NextflowStatus"
                implementation="io.nextflow.intellij.NextflowStatusBarWidgetFactory"/>

        <!-- TextMate grammar bundle -->
        <textmate.bundleProvider
                implementation="io.nextflow.intellij.NextflowTextMateBundleProvider"/>

        <!-- File types with custom icons -->
        <fileType
                name="Nextflow"
                implementationClass="io.nextflow.intellij.NextflowFileType"
                fieldName="INSTANCE"
                extensions="nf"/>
        <fileType
                name="Nextflow Test"
                implementationClass="io.nextflow.intellij.NextflowTestFileType"
                fieldName="INSTANCE"
                fileNameEnding=".nf.test"/>
        <fileType
                name="Nextflow Config"
                implementationClass="io.nextflow.intellij.NextflowConfigFileType"
                fieldName="INSTANCE"
                fileNames="nextflow.config"/>
    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server id="io.nextflow.languageServer"
                name="Nextflow Language Server"
                factoryClass="io.nextflow.intellij.lsp.NextflowLanguageServerFactory">
            <description><![CDATA[
                Nextflow Language Server for .nf, .nf.test, and nextflow.config files.
            ]]></description>
        </server>
        <fileTypeMapping fileType="Nextflow"
                         serverId="io.nextflow.languageServer"
                         languageId="nextflow"/>
        <fileTypeMapping fileType="Nextflow Test"
                         serverId="io.nextflow.languageServer"
                         languageId="nextflow"/>
        <fileTypeMapping fileType="Nextflow Config"
                         serverId="io.nextflow.languageServer"
                         languageId="nextflow-config"/>
    </extensions>

    <actions>
        <action id="io.nextflow.intellij.previewDag"
                class="io.nextflow.intellij.dag.NextflowDagPreviewAction"
                text="Preview Nextflow DAG"
                description="Generate a Mermaid DAG preview for the selected Nextflow workflow"
                icon="/icons/nextflow.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
