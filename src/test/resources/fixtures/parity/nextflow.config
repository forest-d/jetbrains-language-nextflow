/*
 * Nextflow config fixture for feature-parity testing.
 * Exercises: params, profiles, process directives, executor config,
 * manifest block, and conditional includes.
 */

params {
    input_dir   = './data'
    output_dir  = './results'
    genome      = 'GRCh38'
    reads       = "${params.input_dir}/*_{R1,R2}.fastq.gz"
    skip_qc     = false
    max_cpus    = 16
    max_memory  = '128.GB'
    max_time    = '48.h'
}

process {
    cpus   = 2
    memory = '4.GB'
    time   = '1.h'

    withName: 'FASTQC' {
        cpus   = 4
        memory = '8.GB'
    }

    withLabel: 'high_memory' {
        memory = '32.GB'
    }

    withName: 'MULTIQC' {
        cpus   = 1
        memory = '2.GB'
    }
}

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor       = 'slurm'
        process.queue          = 'normal'
        process.clusterOptions = '--account=mylab'
    }

    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    test {
        params.input_dir  = './test-data'
        params.output_dir = './test-results'
        params.max_cpus   = 2
        params.max_memory = '4.GB'
    }
}

manifest {
    name            = 'parity-test-pipeline'
    author          = 'Test Author'
    description     = 'Pipeline for VS Code feature parity testing'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}

timeline {
    enabled = true
    file    = "${params.output_dir}/timeline.html"
}

report {
    enabled = true
    file    = "${params.output_dir}/report.html"
}

dag {
    enabled = true
    file    = "${params.output_dir}/dag.svg"
}
